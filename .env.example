# Copy this file to .env.local for machine-local testing.
# Required:
TEMORIZE_MODEL_PROVIDER=deepseek
TEMORIZE_API_KEY=your_key_here

# Optional:
TEMORIZE_MODEL=deepseek-chat
# TEMORIZE_API_BASE_URL=https://api.deepseek.com/chat/completions

# Example OpenAI override:
# TEMORIZE_MODEL_PROVIDER=openai
# TEMORIZE_MODEL=gpt-5.4
# TEMORIZE_API_BASE_URL=https://api.openai.com/v1/chat/completions
